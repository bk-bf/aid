#!/usr/bin/env bash
# aid-popup — display a native tmux floating menu and print the chosen item.
#
# Usage:
#   aid-popup -t <title> [options] -- <label>[:<key>] [<label>[:<key>] ...]
#
# Options:
#   -t <title>   Menu title (required)
#   -x <pos>     Horizontal position (default: C — centred)
#   -y <pos>     Vertical position   (default: C — centred)
#   -d <secs>    Dismiss timeout in seconds; fires empty choice (default: 10)
#
# Each argument after -- is a menu item of the form:
#   label        — shown in menu; no shortcut key
#   label:key    — shown in menu; key is the single-character shortcut
#
# Separator lines can be inserted by passing the special token "-".
#
# Output:
#   Prints the chosen label (without the :key suffix) to stdout.
#   Prints nothing if the menu was dismissed (Escape / timeout).
#   Exit code is always 0.
#
# Examples:
#   # Simple yes/no
#   answer=$(aid-popup -t "Delete this conversation?" -- "Yes:y" "No:n")
#   [[ "$answer" == "Yes" ]] && do_delete
#
#   # Three choices
#   choice=$(aid-popup -t "What now?" -- "Open:o" "Rename:r" "Delete:d" "-" "Cancel:c")
#
# Environment:
#   AID_DEBUG_LOG  — if set, debug lines are appended to this file
#
# Implementation note:
#   Menu item commands use native tmux `set-environment -g` to record the
#   chosen label in the tmux global environment.  This runs synchronously in
#   the tmux server when the item is selected, so the answer is always
#   available immediately after `display-menu` returns — no fifo or run-shell
#   needed.

set -euo pipefail

# ── Defaults ──────────────────────────────────────────────────────────────────
_title=""
_x="C"
_y="C"
_timeout=10

# ── Argument parsing ──────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -t) _title="$2";   shift 2 ;;
    -x) _x="$2";       shift 2 ;;
    -y) _y="$2";       shift 2 ;;
    -d) _timeout="$2"; shift 2 ;;
    --) shift; break ;;
    *)  break ;;        # allow calling without -- for simple cases
  esac
done

if [[ -z "$_title" ]]; then
  printf 'aid-popup: -t <title> is required\n' >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  printf 'aid-popup: at least one menu item required\n' >&2
  exit 1
fi

# ── Debug helper ──────────────────────────────────────────────────────────────
_dbg() {
  [[ -z "${AID_DEBUG_LOG:-}" ]] && return 0
  local _ms; _ms=$(date +%s%3N 2>/dev/null || printf '%s000' "$(date +%s)")
  printf '%s POPUP %s\n' "$_ms" "$*" >> "$AID_DEBUG_LOG"
}

# ── Unique environment variable for this invocation ───────────────────────────
# Use a per-invocation variable name so nested/concurrent popups don't collide.
_envvar="AID_POPUP_$$"

# Seed the variable as empty so show-environment always finds it.
tmux -L aid set-environment -g "$_envvar" ""

_dbg "envvar=${_envvar} title='${_title}' items=$*"

# ── Build menu items ──────────────────────────────────────────────────────────
# display-menu takes:  name  key  command  [name key command ...]
#
# Each item command is a native tmux `set-environment` call — it runs
# synchronously inside the tmux server when the item is selected, so the value
# is present the moment display-menu returns.
_menu_args=()
for _item in "$@"; do
  if [[ "$_item" == "-" ]]; then
    # Separator line
    _menu_args+=("" "" "")
    continue
  fi
  # Split on the last colon to get label and optional key.
  if [[ "$_item" == *:? ]]; then
    _label="${_item%:?}"
    _key="${_item##*:}"
  else
    _label="$_item"
    _key=""
  fi
  _menu_args+=("$_label" "$_key" "set-environment -g ${_envvar} $(printf '%q' "$_label")")
done

# ── Show the menu (blocks until user picks or presses Escape) ─────────────────
tmux -L aid display-menu \
  -T " ${_title} " \
  -x "$_x" \
  -y "$_y" \
  "${_menu_args[@]}" \
  2>/dev/null || true

# Brief pause so tmux can fully repaint the pane after the menu overlay closes
# before the caller restarts fzf on top of it.
sleep 0.15

# ── Collect answer ────────────────────────────────────────────────────────────
# show-environment prints "VAR=value"; strip the "VAR=" prefix.
_raw=$(tmux -L aid show-environment -g "$_envvar" 2>/dev/null || true)
_answer="${_raw#"${_envvar}="}"

# Clean up the environment variable.
tmux -L aid set-environment -g -u "$_envvar" 2>/dev/null || true

_dbg "answer='${_answer:-<dismissed>}'"
printf '%s' "$_answer"
