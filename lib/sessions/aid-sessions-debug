#!/usr/bin/env bash
# aid-sessions-debug — live debug log viewer for the aid-sessions navigator.
#
# Runs in a dedicated tmux pane (right side of the orchestrator layout).
# Tails AID_DEBUG_LOG and renders each event with colour-coded prefixes.
#
# Log format written by aid-sessions:
#   <unix_ms> <category> <message>
#
# Categories:
#   TICK   — background ticker fired
#   POS    — cursor position captured / restored
#   RELOAD — reload dispatched to fzf
#   KEY    — key / action from user
#   INIT   — startup events
#   HTTP   — curl result for --listen POST
#   ERR    — error
#
# Env: AID_DEBUG_LOG (path to log file; required)

set -euo pipefail

: "${AID_DEBUG_LOG:?AID_DEBUG_LOG must be set}"

# Create log file if it doesn't exist yet.
mkdir -p "$(dirname "$AID_DEBUG_LOG")"
touch "$AID_DEBUG_LOG"

# Colour map per category.
_colour() {
  case "$1" in
    TICK)   printf '\033[2;36m'   ;;   # dim cyan
    POS)    printf '\033[1;33m'   ;;   # bold yellow
    RELOAD) printf '\033[1;32m'   ;;   # bold green
    KEY)    printf '\033[1;35m'   ;;   # bold magenta
    INIT)   printf '\033[1;34m'   ;;   # bold blue
    HTTP)   printf '\033[0;36m'   ;;   # cyan
    ERR)    printf '\033[1;31m'   ;;   # bold red
    *)      printf '\033[0m'      ;;
  esac
}
_reset() { printf '\033[0m'; }

# Header banner.
printf '\033[1;34m┌─ aid-sessions debug log ─────────────────────────────────────┐\033[0m\n'
printf '\033[2m  log: %s\033[0m\n' "$AID_DEBUG_LOG"
printf '\033[2m  waiting for events…\033[0m\n'
printf '\033[1;34m└───────────────────────────────────────────────────────────────┘\033[0m\n'

# Tail the log file, colouring each line as it arrives.
tail -F "$AID_DEBUG_LOG" 2>/dev/null | while IFS= read -r line; do
  # Expected format: "<ms> <CAT> <rest>"
  ms="${line%% *}"
  rest="${line#* }"
  cat="${rest%% *}"
  msg="${rest#* }"

  # Convert ms to HH:MM:SS.mmm
  ts_s=$(( ms / 1000 ))
  ts_ms=$(( ms % 1000 ))
  ts=$(date -d "@${ts_s}" '+%H:%M:%S' 2>/dev/null || date -r "${ts_s}" '+%H:%M:%S' 2>/dev/null || printf '%s' "$ts_s")
  ts_full=$(printf '%s.%03d' "$ts" "$ts_ms")

  col=$(_colour "$cat")
  rst=$(_reset)
  printf '%s\033[2m%s\033[0m %s%-7s%s %s\n' \
    "" "$ts_full" "$col" "$cat" "$rst" "$msg"
done
